# Local application runtime database
DATABASE_URL=postgresql://pennywise:pennywise@localhost:5432/pennywise

# Local DB-backed API test database
TEST_DATABASE_URL=postgresql://pennywise:pennywise@localhost:5432/pennywise_test

# Session signing secret for local development
SESSION_SECRET=change-me

# Seeded demo credentials used locally and in deployment
DEMO_USERNAME=demo
DEMO_PASSWORD=demo-password

# Local default port; Render provides its own runtime port
PORT=3000
