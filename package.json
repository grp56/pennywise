{
  "name": "pennywise",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @pennywise/api --filter @pennywise/web run dev",
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "pnpm -r --if-present run test && pnpm run test:e2e",
    "test:e2e": "playwright test ./apps/web/e2e --pass-with-no-tests",
    "smoke:prod": "pnpm run smoke:prod:build && pnpm run smoke:prod:start",
    "smoke:prod:build": "pnpm build",
    "smoke:prod:start": "pnpm --filter @pennywise/api start",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @pennywise/api run db:migrate",
    "db:seed": "pnpm --filter @pennywise/api run db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.54.2",
    "typescript": "^5.8.2"
  }
}
